# PostgreSQL connection (spec §4: Supabase/Neon recommended).
# DATABASE_URL          = pooled connection, used by the app at runtime.
# DATABASE_URL_UNPOOLED = direct connection, used for schema sync (`prisma db push`).
# On Vercel, the Neon integration sets BOTH of these automatically — you don't edit them there.
# For local dev, both can point at the same local Postgres instance:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Square / QuickBooks credentials (server-side only). Phase 1 uses a mock, so these
# stay unset; the mock activates automatically when SQUARE_ACCESS_TOKEN is absent.
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=

# Optional: pin the app's notion of "today" (otherwise the system clock is used).
# APP_TODAY="2026-06-18"
