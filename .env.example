# SQLite dev database. For production, point this at Postgres (Supabase/Neon)
# and change the datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Square / QuickBooks credentials (server-side only). Phase 1 uses a mock, so these
# are unset; the mock activates automatically when SQUARE_ACCESS_TOKEN is absent.
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=

# Pins the app's notion of "today" so the demo aligns with seeded history.
# Remove this in real use to follow the system clock.
APP_TODAY="2026-06-18"
