{
  "name": "ysb",
  "version": "0.1.0",
  "private": true,
  "description": "Yard Sale Bagels — Operations Dashboard (Phase 1)",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --skip-generate --accept-data-loss && (tsx prisma/seed.ts || echo 'seed skipped') && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset --accept-data-loss && tsx prisma/seed.ts",
    "test": "tsx --test src/lib/forecast.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
